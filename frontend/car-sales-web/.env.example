# Frontend environment template


# Backend API base URL.
# Local default is http://localhost:3000 if this is omitted.
VITE_API_URL=http://localhost:3000

# Public: deployed Sepolia contract address.
# Must match backend CONTRACT_ADDRESS.
VITE_CONTRACT_ADDRESS=0xD0CF607f0bCD60B5ed02896e682450eA4dBf5BB0

# Demo exchange rate used by UI to display ETH and USD.
# Must match backend USD_PER_ETH to avoid amount mismatch.
VITE_USD_PER_ETH=2000000
