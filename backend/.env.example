# Backend environment template

# Server
PORT=3000
NODE_ENV=development

# Allowed frontend origins for CORS.
# For local development, keep the Vite URL here.
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# MongoDB
# Secret: replace with your real MongoDB connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>

# JWT/session
# Secret: use long random strings in real development/deployment.
JWT_SECRET=replace_with_a_long_random_access_token_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_token_secret
SESSION_SECRET=replace_with_a_long_random_session_secret

# Email SMTP
# Secret: SMTP_PASS should be an app password, not your normal email password.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=replace_with_email_app_password

# Google OAuth
# Optional unless Google login is enabled.
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
CALLBACK_URL=http://localhost:3000/api/users/auth/google/callback

# Blockchain / Sepolia
# Public: deployed contract address currently used by the project.
CONTRACT_ADDRESS=0xD0CF607f0bCD60B5ed02896e682450eA4dBf5BB0

# Public: seller/server wallet address. This must match SEPOLIA_PRIVATE_KEY.
SELLER_WALLET=0x3aB431DC9782DA26bBdB002e94Fa057A13D2049F

# Secret-ish: RPC URLs can contain provider project IDs. Use your own URL.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<your-infura-project-id>

# Secret: never share or commit a real private key.
# This wallet is used by backend to create/confirm/cancel on-chain orders.
SEPOLIA_PRIVATE_KEY=replace_with_seller_wallet_private_key_without_0x

# Demo exchange rate used by backend to convert USD to ETH.
USD_PER_ETH=2000000
