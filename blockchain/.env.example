# Blockchain/Hardhat environment template
# Copy this file to `.env` before deploying or verifying contracts.
# Do not commit real private keys, RPC project IDs, or Etherscan API keys.

# Secret-ish: RPC URLs can include provider project IDs.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<your-infura-project-id>

# Secret: deployer/seller private key without 0x.
# For this project, the deployed app expects this wallet to match SELLER_WALLET in backend.
SEPOLIA_PRIVATE_KEY=replace_with_deployer_or_seller_private_key_without_0x

# Secret: needed only for Etherscan verification.
ETHERSCAN_API_KEY=replace_with_etherscan_api_key

# Public: current deployed contract used by backend/frontend.
CONTRACT_ADDRESS=0xD0CF607f0bCD60B5ed02896e682450eA4dBf5BB0
